{
  "name": "resolver",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "ingredient-match-queue-pipeline": "tsx ../orchestrators/ingredient-match-queue-pipeline/pipeline.ts",
    "embedding-queue-pipeline": "tsx ../orchestrators/embedding-queue-pipeline/pipeline.ts",
    "visualize-ingredient-embeddings-pca": "python analysis/visualize-ingredient-embeddings-pca.py",
    "weighted-cluster-projection": "python analysis/weighted-cluster-projection.py",
    "consolidation-candidate-scatter": "python analysis/consolidation-candidate-scatter.py",
    "populate-substitution-proposals": "python analysis/populate-substitution-proposals.py",
    "vector-double-check-pipeline": "tsx ../orchestrators/vector-double-check-pipeline/pipeline.ts",
    "canonical-consolidation-pipeline": "tsx ../orchestrators/canonical-consolidation-pipeline/pipeline.ts",
    "canonical-medoid-pipeline": "tsx ../orchestrators/canonical-medoid-pipeline/pipeline.ts",
    "canonical-pipeline": "tsx ../orchestrators/canonical-pipeline/pipeline.ts",
    "ingredient-match-queue-pipeline-runner": "tsx ../orchestrators/ingredient-match-queue-pipeline/runner.ts",
    "canonical-medoid-pipeline-runner": "tsx ../orchestrators/canonical-medoid-pipeline/runner.ts",
    "regenerate-mappings": "node regenerate-mappings.js",
    "standardizer-baseline": "tsx --env-file=../../.env.local reports/ingredient-standardizer-baseline.ts",
    "standardizer-baseline:json": "tsx --env-file=../../.env.local reports/ingredient-standardizer-baseline.ts --json"
  },
  "dependencies": {
    "@google/genai": "latest",
    "@sparticuz/chromium": "latest",
    "@supabase/supabase-js": "latest",
    "axios": "latest",
    "dotenv": "latest",
    "he": "latest",
    "playwright-core": "latest",
    "tsx": "^4.21.0"
  }
}
