RUN npm ci --omit=dev

COPY tsconfig.json ./tsconfig.json
COPY lib/ollama ./lib/ollama
COPY scripts ./scripts

CMD ["node_modules/.bin/tsx", "scripts/remap-product-mappings-vector.ts"]
