FROM node:20-slim

WORKDIR /app

COPY package.json ./package.json
RUN npm install --omit=dev --no-audit --no-fund

COPY scrapers ./scrapers
COPY scripts ./scripts

ENV NODE_ENV=production
ENV DAILY_SCRAPER_DRY_RUN=true
ENV STORE_CONCURRENCY=1
ENV SCRAPER_BATCH_CONCURRENCY=1
ENV SCRAPER_BATCH_SIZE=5
ENV STORE_LIMIT=1
ENV INGREDIENT_LIMIT=5
ENV INGREDIENT_DELAY_MS=0

CMD ["node", "scripts/daily-scraper.js"]
